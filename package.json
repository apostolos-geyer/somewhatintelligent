{
  "name": "somewhatintelligent",
  "version": "0.2.1",
  "private": true,
  "workspaces": [
    "workers/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun scripts/dev-stack.ts",
    "dev:doctor": "bun scripts/dev-doctor.ts",
    "build": "vp run -r build",
    "check": "vp check",
    "test": "vp test",
    "secrets": "bun packages/secrets/bin/secrets.ts",
    "migrate": "vp run -r db:migrate:local",
    "bootstrap": "vp run -r env:init",
    "seed": "vp run -r seed",
    "db:generate": "vp run -r db:generate",
    "db:push": "vp run -r db:push",
    "types": "vp run -r types",
    "typecheck": "vp run -r typecheck",
    "browsers:install": "bun scripts/setup-browsers.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "typecheck:e2e": "tsgo --noEmit -p e2e/tsconfig.json",
    "ready": "vp check && vp run -r typecheck && vp run -r test && vp run -r build",
    "prepare": "vp config && git config core.hooksPath .githooks"
  },
  "dependencies": {
    "jose": "^6.2.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/bun": "latest",
    "@typescript/native-preview": "7.0.0-dev.20260502.1",
    "agent-browser": "^0.27.3",
    "cloudflare": "catalog:",
    "fallow": "^2.63.0",
    "playwright-core": "^1.61.0",
    "portless": "^0.14.0",
    "shadcn": "^4.1.2",
    "typescript": "5.9.2",
    "vite-plus": "catalog:",
    "wrangler": "^4.81.1"
  },
  "overrides": {
    "kysely": "^0.28.17",
    "miniflare": "4.20260515.0",
    "vite": "catalog:",
    "vitest": "catalog:",
    "workerd": "1.20260515.1",
    "wrangler": "4.92.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.11",
  "catalog": {
    "cloudflare": "6.4.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.24",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.24",
    "vite-plus": "0.1.24",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/node": "^25.5.2",
    "@tanstack/react-start": "1.168.18",
    "ulidx": "^2.4.1",
    "better-auth": "^1.6.0",
    "stripe": "^20.4.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-kit": "^0.31.10",
    "@libsql/client": "^0.17.2",
    "@t3-oss/env-nextjs": "^0.13.11",
    "arktype": "^2.2.0",
    "tailwindcss": "^4",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/vite": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/config": "^0.1.0",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "sonner": "^2.0.7",
    "motion": "^12.38.0",
    "zustand": "^5.0.12",
    "partyserver": "^0.5",
    "partysocket": "^1",
    "@posthog/react": "1.10.3",
    "posthog-js": "1.398.1",
    "posthog-node": "5.39.4"
  }
}
