{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "include-component-in-tag": true,
  "include-v-in-tag": true,
  "tag-separator": "-",
  "separate-pull-requests": false,
  "group-pull-request-title-pattern": "chore: release ${branch}",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "bootstrap-sha": "db87d84610030003171d0cac889b492f7b6ec967",
  "packages": {
    "workers/bouncer": {
      "component": "bouncer",
      "extra-files": [{ "type": "json", "path": "package.json", "jsonpath": "$.version" }]
    },
    "workers/guestlist": {
      "component": "guestlist",
      "extra-files": [{ "type": "json", "path": "package.json", "jsonpath": "$.version" }]
    },
    "workers/promoter": {
      "component": "promoter",
      "extra-files": [{ "type": "json", "path": "package.json", "jsonpath": "$.version" }]
    },
    "workers/roadie": {
      "component": "roadie",
      "extra-files": [{ "type": "json", "path": "package.json", "jsonpath": "$.version" }]
    },
    "workers/identity": {
      "component": "identity",
      "extra-files": [{ "type": "json", "path": "package.json", "jsonpath": "$.version" }]
    },
    "workers/store": {
      "component": "store",
      "extra-files": [{ "type": "json", "path": "package.json", "jsonpath": "$.version" }]
    }
  },
  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "perf", "section": "Performance" },
    { "type": "revert", "section": "Reverts" },
    { "type": "refactor", "section": "Refactors" },
    { "type": "ci", "section": "CI / Deploy", "hidden": false },
    { "type": "build", "section": "Build System", "hidden": true },
    { "type": "docs", "section": "Documentation", "hidden": true },
    { "type": "test", "section": "Tests", "hidden": true },
    { "type": "chore", "section": "Chores", "hidden": true },
    { "type": "style", "section": "Styles", "hidden": true }
  ]
}
