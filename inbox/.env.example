# Deploy-time inputs for the Alchemy stack (alchemy.run.ts).
# Copy to .env — alchemy loads it when running `bun run deploy` / `bun run plan`.

# The Zero Trust team domain the app validates Access JWTs against.
# Base URL or the full /cdn-cgi/access/certs URL both work.
TEAM_DOMAIN=https://<team>.cloudflareaccess.com

# Cloudflare credentials: EITHER run `bun alchemy login` once (stored profile),
# OR use non-interactive env-token auth by uncommenting all three below.
# The token needs: Workers Scripts, R2, Access (apps + policies),
# Email Routing (zone), Zone Read. scripts/provision-token.mjs can mint it.
#CI=1
#CLOUDFLARE_API_TOKEN=
#CLOUDFLARE_ACCOUNT_ID=c735c5a53d864bee37400befb7f4c7f4
