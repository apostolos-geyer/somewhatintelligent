{
  "name": "@si/design",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./tokens": "./src/tokens/index.ts",
    "./tokens/*": "./src/tokens/*.ts",
    "./generated/*": "./generated/*",
    "./fonts/*": "./src/fonts/*",
    "./assets/*": "./src/assets/*",
    "./assets.css": "./src/assets.css",
    "./theme.css": "./src/theme.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "codegen": "bun run scripts/codegen.ts",
    "audit:contrast": "bun run scripts/audit-contrast.ts",
    "brand-lint": "bun run scripts/brand-lint.ts",
    "test": "bun test scripts",
    "build": "bun run codegen && bun run audit:contrast"
  },
  "devDependencies": {
    "@storybook/react": "^10",
    "@tailwindcss/typography": "catalog:",
    "@types/react": "catalog:",
    "bun-types": "^1.3.14",
    "shadcn": "^4.1.2",
    "tailwindcss": "catalog:",
    "tw-animate-css": "^1.4.0"
  }
}
