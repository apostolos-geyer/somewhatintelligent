{
  "name": "@greenroom/design",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./tokens": "./src/tokens/index.ts",
    "./tokens/*": "./src/tokens/*.ts",
    "./generated/*": "./generated/*",
    "./fonts/*": "./src/fonts/*",
    "./assets/*": "./src/assets/*",
    "./assets.css": "./src/assets.css",
    "./theme.css": "./src/theme.css"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "codegen": "bun run scripts/codegen.ts",
    "audit:contrast": "bun run scripts/audit-contrast.ts",
    "build": "bun run codegen && bun run audit:contrast"
  },
  "devDependencies": {
    "@greenroom/typescript-config": "workspace:*",
    "@storybook/react": "^10",
    "@tailwindcss/typography": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/react": "catalog:",
    "shadcn": "^4.1.2",
    "tailwindcss": "catalog:",
    "tw-animate-css": "^1.4.0",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  }
}
