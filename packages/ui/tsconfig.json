{
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["@testing-library/jest-dom"],
    "paths": {
      "@si/ui/*": ["./src/*"]
    }
  },
  "include": ["src", "__tests__/**/*.ts"],
  "exclude": ["node_modules"]
}
