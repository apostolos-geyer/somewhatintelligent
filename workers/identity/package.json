{
  "name": "identity",
  "version": "0.0.8",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "portless",
    "dev:bare": "vp dev",
    "env:init": "bun scripts/env-init.ts",
    "dev:solo": "bun ../../scripts/dev-solo.ts",
    "preview": "vp preview",
    "deploy": "vp run build && wrangler deploy",
    "deploy:staging": "APP_BUILD=1 vp run build && wrangler deploy",
    "deploy:production": "CLOUDFLARE_ENV=production vp run build && wrangler deploy --env production",
    "types": "wrangler types -c ./wrangler.jsonc -c ../guestlist/wrangler.jsonc -c ../roadie/wrangler.jsonc",
    "typecheck": "bun run types && tsgo --noEmit",
    "test": "vp test run"
  },
  "dependencies": {
    "@si/analytics": "workspace:*",
    "@si/design": "workspace:*",
    "@si/ui": "workspace:*",
    "@somewhatintelligent/auth": "0.0.3",
    "@somewhatintelligent/guestlist": "0.0.6",
    "@somewhatintelligent/kit": "0.0.3",
    "@somewhatintelligent/og": "0.0.2",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-devtools": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-router-devtools": "catalog:",
    "@tanstack/react-start": "catalog:",
    "arktype": "catalog:",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "simple-icons": "^16.16.0",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tanstack/devtools-vite": "catalog:",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^28.1.0",
    "jsonc-parser": "^3.3.1",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "portless": {
    "name": "identity.somewhatintelligent",
    "script": "dev:bare"
  }
}
