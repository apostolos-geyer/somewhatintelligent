{
  "name": "store",
  "version": "0.0.6",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "portless",
    "dev:bare": "WRANGLER_REGISTRY_PATH=${WRANGLER_REGISTRY_PATH:-$PWD/../../.wrangler/dev-registry} wrangler dev --port ${STORE_PORT:-8793} --inspector-port ${STORE_INSPECTOR_PORT:-0}",
    "env:init": "bun scripts/env-init.ts",
    "dev:solo": "bun ../../scripts/dev-solo.ts",
    "deploy:staging": "wrangler deploy",
    "deploy:production": "wrangler deploy --env production",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:staging": "wrangler d1 migrations apply DB --remote",
    "db:migrate:production": "wrangler d1 migrations apply DB --remote --env production",
    "seed": "bun scripts/seed.ts",
    "types": "wrangler types -c ./wrangler.jsonc -c ../guestlist/wrangler.jsonc -c ../roadie/wrangler.jsonc",
    "typecheck": "tsgo --noEmit",
    "test": "vp test run",
    "test:pool": "vp test run -c ./vitest.pool.config.ts"
  },
  "dependencies": {
    "@si/config": "workspace:*",
    "@si/contracts": "workspace:*",
    "@si/roadie-service": "workspace:*",
    "@somewhatintelligent/auth": "0.0.3",
    "@somewhatintelligent/guestlist": "0.0.6",
    "@somewhatintelligent/kit": "0.0.3",
    "@somewhatintelligent/stripe": "0.0.1",
    "arktype": "catalog:",
    "drizzle-orm": "catalog:",
    "hono": "^4.12.31",
    "stripe": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.6",
    "@si/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "^5.7.2",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "portless": {
    "name": "store.somewhatintelligent",
    "script": "dev:bare"
  }
}
