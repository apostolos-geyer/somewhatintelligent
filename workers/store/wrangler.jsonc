{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "si-store-staging",
  "account_id": "c735c5a53d864bee37400befb7f4c7f4",
  "main": "./src/worker.ts",
  "compatibility_date": "2026-04-16",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
  },
  "upload_source_maps": true,
  "workers_dev": true,
  "preview_urls": true,
  "vars": {
    "ENVIRONMENT": "staging",
    // The store's own PUBLIC address. Used for the bouncer envelope
    // `expectedHost` check (src/lib/platform.ts) — store is headless behind
    // bouncer (RFC-0001 D12: `/api/store` + `/hooks/store` passthrough only,
    // no vmf mount; the storefront pages are Site's).
    "STORE_URL": "https://staging.somewhatintelligent.ca/shop",
    // Site's PUBLIC apex — the base for the `/api/store` checkout return URL
    // (`${SITE_URL}/checkout/return`), which renders on Site, not the headless
    // Store worker (RFC-0001 D11). See docs/ops/env-vars.md.
    "SITE_URL": "https://staging.somewhatintelligent.ca",
    // Stripe publishable key (pk_…, client-safe). Blank until Stripe
    // onboarding; relayed to Site's checkout island via GET /api/store/config.
    "STRIPE_PUBLISHABLE_KEY": "",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "store-staging-db",
      "migrations_dir": "migrations",
      // TODO(provision): real D1 database_id from this fork's Cloudflare account.
      "database_id": "d197e866-4587-4981-bacc-ef01266498c8",
    },
  ],
  "queues": {
    "producers": [{ "binding": "STRIPE_EVENTS", "queue": "si-stripe-events-staging" }],
    "consumers": [
      {
        "queue": "si-stripe-events-staging",
        "dead_letter_queue": "si-stripe-events-dlq-staging",
        "max_retries": 5,
      },
      // Terminal consumer: no dead_letter_queue behind it. processDlqBatch acks
      // after persisting evidence; max_retries only backs its one retry case —
      // the dead-letter INSERT itself failing (see stripe-queue.ts).
      { "queue": "si-stripe-events-dlq-staging", "max_retries": 5 },
    ],
  },
  // Reconciliation sweep — releases orphaned/stale-attached stock reservations
  // no webhook can cover (worker.ts scheduled(), Track D5/D6). Named envs don't
  // inherit, so env.production re-declares this.
  "triggers": {
    "crons": ["*/15 * * * *"],
  },
  "services": [
    { "binding": "GUESTLIST", "service": "si-guestlist-staging", "entrypoint": "Guestlist" },
    {
      "binding": "ROADIE",
      "service": "si-roadie-staging",
      // entrypoint + props.callerApp are MANDATORY on every ROADIE binding —
      // without them roadie's readCallerApp throws on every call (reads AND
      // uploads). See CLAUDE.md's roadie section + guestlist's wrangler.jsonc.
      "entrypoint": "Roadie",
      "props": { "callerApp": "store" },
    },
  ],
  "env": {
    "production": {
      "name": "si-store-production",
      "workers_dev": false,
      "preview_urls": false,
      "vars": {
        "ENVIRONMENT": "production",
        "STORE_URL": "https://somewhatintelligent.ca/shop",
        "SITE_URL": "https://somewhatintelligent.ca",
        "STRIPE_PUBLISHABLE_KEY": "",
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "store-production-db",
          "migrations_dir": "migrations",
          // TODO(provision): real D1 database_id from this fork's Cloudflare account.
          "database_id": "39ab2bc9-8491-4ee8-8b77-56a8996abfd9",
        },
      ],
      "queues": {
        "producers": [{ "binding": "STRIPE_EVENTS", "queue": "si-stripe-events-production" }],
        "consumers": [
          {
            "queue": "si-stripe-events-production",
            "dead_letter_queue": "si-stripe-events-dlq-production",
            "max_retries": 5,
          },
          // Terminal consumer — see the staging note above.
          { "queue": "si-stripe-events-dlq-production", "max_retries": 5 },
        ],
      },
      "triggers": {
        "crons": ["*/15 * * * *"],
      },
      "services": [
        {
          "binding": "GUESTLIST",
          "service": "si-guestlist-production",
          "entrypoint": "Guestlist",
        },
        {
          "binding": "ROADIE",
          "service": "si-roadie-production",
          "entrypoint": "Roadie",
          "props": { "callerApp": "store" },
        },
      ],
      "observability": {
        "enabled": true,
        "head_sampling_rate": 1,
        "logs": {
          "enabled": true,
        },
      },
    },
  },
}
