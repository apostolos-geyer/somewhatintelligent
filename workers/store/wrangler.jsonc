{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "si-store-staging",
  "account_id": "c735c5a53d864bee37400befb7f4c7f4",
  "main": "./src/worker.ts",
  "compatibility_date": "2026-04-16",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
  },
  "upload_source_maps": true,
  "workers_dev": true,
  "preview_urls": true,
  "vars": {
    "ENVIRONMENT": "staging",
    // The mount prefix, exposed to the client bundle (vite.config CLIENT_VARS)
    // as the SINGLE source for the client-only TanStack Router basepath
    // (src/lib/basepath.ts + src/router.tsx). Bouncer vmf-mounts the store at
    // `/shop`, stripping it inbound (server serves at root) and rewriting
    // assets outbound; the client router re-applies `/shop` to the URL bar so
    // in-app navigation + hard refresh keep the prefix. Local dev-direct sets
    // "/" via .dev.vars.
    "PUBLIC_BASE": "/shop",
    // The store's own PUBLIC address (vmf-mounted at `/shop`). Used for
    // self-referencing absolute links.
    "STORE_URL": "https://staging.somewhatintelligent.ca/shop",
    // Identity's PUBLIC address — the store links here for sign-in
    // (`${IDENTITY_URL}/sign-in`) and derives the same-origin `/api` auth base
    // from it on the SSR side (new URL(IDENTITY_URL).origin), mirroring
    // workers/identity/src/lib/auth-client.ts.
    "IDENTITY_URL": "https://staging.somewhatintelligent.ca/account",
    // Controlled apex (leading dot) — cross-subdomain cookie domain + the
    // auth server's `*.{apex}` trustedOrigins.
    "AUTH_DOMAIN": ".somewhatintelligent.ca",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "store-staging-db",
      "migrations_dir": "migrations",
      // TODO(provision): real D1 database_id from this fork's Cloudflare account.
      "database_id": "d197e866-4587-4981-bacc-ef01266498c8",
    },
  ],
  "services": [
    { "binding": "GUESTLIST", "service": "si-guestlist-staging" },
    {
      "binding": "ROADIE",
      "service": "si-roadie-staging",
      // entrypoint + props.callerApp are MANDATORY on every ROADIE binding —
      // without them roadie's readCallerApp throws on every call (reads AND
      // uploads). See CLAUDE.md's roadie section + guestlist's wrangler.jsonc.
      "entrypoint": "Roadie",
      "props": { "callerApp": "store" },
    },
  ],
  "env": {
    "production": {
      "name": "si-store-production",
      "workers_dev": false,
      "preview_urls": false,
      "vars": {
        "ENVIRONMENT": "production",
        "PUBLIC_BASE": "/shop",
        "STORE_URL": "https://somewhatintelligent.ca/shop",
        "IDENTITY_URL": "https://somewhatintelligent.ca/account",
        "AUTH_DOMAIN": ".somewhatintelligent.ca",
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "store-production-db",
          "migrations_dir": "migrations",
          // TODO(provision): real D1 database_id from this fork's Cloudflare account.
          "database_id": "00000000-0000-0000-0000-000000000000",
        },
      ],
      "services": [
        { "binding": "GUESTLIST", "service": "si-guestlist-production" },
        {
          "binding": "ROADIE",
          "service": "si-roadie-production",
          "entrypoint": "Roadie",
          "props": { "callerApp": "store" },
        },
      ],
      "observability": {
        "enabled": true,
        "head_sampling_rate": 1,
        "logs": {
          "enabled": true,
        },
      },
    },
  },
}
