{
  "name": "@greenroom/guestlist-service",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./auth": "./src/auth.ts",
    "./client": "./src/client/index.ts",
    "./client/react": "./src/client/react.ts"
  },
  "scripts": {
    "dev": "WRANGLER_REGISTRY_PATH=${WRANGLER_REGISTRY_PATH:-$PWD/../../.wrangler/dev-registry} wrangler dev --port ${GUESTLIST_PORT:-8787} --inspector-port ${GUESTLIST_INSPECTOR_PORT:-0}",
    "env:init": "bun scripts/env-init.ts",
    "dev:solo": "bun ../../scripts/dev-solo.ts",
    "deploy:staging": "wrangler deploy",
    "deploy:production": "wrangler deploy --env production",
    "db:generate": "drizzle-kit generate",
    "db:migrate:staging": "wrangler d1 migrations apply DB --remote",
    "db:migrate:production": "wrangler d1 migrations apply DB --remote --env production",
    "types": "wrangler types -c wrangler.jsonc -c ../promoter/wrangler.jsonc -c ../roadie/wrangler.jsonc",
    "typecheck": "tsgo --noEmit",
    "test": "vp test run"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.6.0",
    "@better-auth/core": "^1.6.9",
    "@better-auth/oauth-provider": "^1.6.0",
    "@better-auth/passkey": "^1.6.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^1.4.9",
    "@greenroom/config": "workspace:*",
    "@greenroom/kit": "workspace:*",
    "@greenroom/promoter-service": "workspace:*",
    "@greenroom/roadie-service": "workspace:*",
    "better-auth": "catalog:",
    "cookie-es": "^3.1.1",
    "drizzle-orm": "catalog:",
    "elysia": "^1.4.7"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.6",
    "@cloudflare/workers-types": "^4",
    "@greenroom/typescript-config": "workspace:*",
    "drizzle-kit": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "wrangler": "^4"
  }
}
