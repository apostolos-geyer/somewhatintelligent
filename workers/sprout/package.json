{
  "name": "sprout",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "portless",
    "dev:bare": "vp dev",
    "env:init": "bun scripts/env-init.ts",
    "dev:solo": "bun ../../scripts/dev-solo.ts",
    "preview": "vp preview",
    "deploy": "vp run build && wrangler deploy",
    "deploy:staging": "GREENROOM_BUILD=1 vp run build && wrangler deploy",
    "deploy:production": "CLOUDFLARE_ENV=production vp run build && wrangler deploy --env production",
    "types": "wrangler types -c ./wrangler.jsonc -c ../guestlist/wrangler.jsonc",
    "typecheck": "tsgo --noEmit",
    "test": "vp test run",
    "db:generate": "drizzle-kit generate",
    "db:migrate:staging": "wrangler d1 migrations apply DB --remote",
    "db:migrate:production": "wrangler d1 migrations apply DB --env production --remote",
    "test:pool": "vp test run -c ./vitest.pool.config.ts"
  },
  "dependencies": {
    "@ai-sdk/react": "1.2.12",
    "@cloudflare/realtimekit-react": "^1.5.1",
    "@cloudflare/realtimekit-react-ui": "^1.2.0",
    "@greenroom/auth": "workspace:*",
    "@greenroom/config": "workspace:*",
    "@greenroom/design": "workspace:*",
    "@greenroom/guestlist-service": "workspace:*",
    "@greenroom/kit": "workspace:*",
    "@greenroom/roadie-service": "workspace:*",
    "@greenroom/ui": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-devtools": "0.10.5",
    "@tanstack/react-router": "1.170.10",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-start": "1.168.18",
    "@tanstack/router-plugin": "1.168.13",
    "ai": "4.3.19",
    "arktype": "catalog:",
    "cloudflare": "catalog:",
    "drizzle-orm": "catalog:",
    "lucide-react": "catalog:",
    "partyserver": "catalog:",
    "partysocket": "catalog:",
    "pdfjs-dist": "5.4.149",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:",
    "unpdf": "1.3.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/vitest-pool-workers": "^0.14.6",
    "@cloudflare/workers-types": "^4",
    "@greenroom/typescript-config": "workspace:*",
    "@tanstack/devtools-vite": "0.7.0",
    "@tanstack/react-form": "^1.28.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "catalog:",
    "jsdom": "^28.1.0",
    "jsonc-parser": "^3.3.1",
    "typescript": "^5.7.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "portless": {
    "name": "sprout.sproutportal",
    "script": "dev:bare"
  }
}
