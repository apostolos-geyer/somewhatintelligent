---
import { SignupForm } from "./signup-form";

// Final early-access push (the prototype's `.final`): a dark forest card sitting
// on the light page. `data-theme="dark"` on the card flips the SEMANTIC tokens
// so text-text-secondary etc. read on dark; the green-waves texture sits behind
// the centred content. Only the <SignupForm> island hydrates.
---

<section class="bg-bg px-6 py-[clamp(64px,9vw,130px)]">
  <div class="mx-auto max-w-[1180px]">
    <div
      data-theme="dark"
      class="relative overflow-hidden rounded-[clamp(24px,4vw,44px)] bg-indica-green px-[clamp(28px,5vw,80px)] py-[clamp(56px,8vw,110px)] text-center"
    >
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 bg-cover bg-center opacity-[0.26] mix-blend-screen"
        style="background-image: var(--texture-green-waves)"
      >
      </div>
      <div class="relative z-[2]">
        <p class="font-accent text-[clamp(28px,5vw,52px)] leading-none text-sprout-green">
          grow with us
        </p>
        <h2 class="mt-2 font-display text-3xl leading-[1.05] tracking-[0.01em] text-cream sm:text-4xl lg:text-5xl">
          Be first to grow with Sprout
        </h2>
        <p class="mx-auto mt-[18px] max-w-[52ch] text-lg text-text-secondary">
          Join the early-access list and we&apos;ll let you know the moment the
          doors open. <span class="text-sprout-green">Learn green, earn green.</span>
        </p>
        <div class="mx-auto mt-8 max-w-[480px]">
          <SignupForm client:visible onDark source="final" />
        </div>
      </div>
    </div>
  </div>
</section>
