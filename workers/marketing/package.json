{
  "name": "marketing",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless",
    "dev:solo": "bun ../../scripts/dev-solo.ts",
    "dev:bare": "wrangler types && astro dev",
    "preview": "astro preview",
    "deploy": "vp run build && wrangler deploy",
    "deploy:staging": "GREENROOM_BUILD=1 vp run build && wrangler deploy",
    "deploy:production": "CLOUDFLARE_ENV=production vp run build && wrangler deploy --env production",
    "types": "wrangler types",
    "typecheck": "astro sync && tsgo --noEmit"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "13.3.0",
    "@astrojs/react": "5.0.4",
    "@greenroom/config": "workspace:*",
    "@greenroom/design": "workspace:*",
    "@greenroom/ui": "workspace:*",
    "astro": "6.2.1",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "^6.0.3",
    "wrangler": "^4.81.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsonc-parser": "^3.3.1",
    "tailwindcss": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "overrides": {
    "vite": "^7"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "portless": {
    "name": "marketing.sproutportal",
    "script": "dev:bare"
  }
}
