{
  "name": "@si/bouncer-service",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless",
    "dev:bare": "wrangler dev --port $PORT",
    "env:init": "bun scripts/env-init.ts",
    "dev:solo": "bun ../../scripts/dev-solo.ts",
    "build": "wrangler deploy --dry-run",
    "deploy:staging": "wrangler deploy",
    "deploy:production": "wrangler deploy --env production",
    "types": "wrangler types -c wrangler.jsonc -c ../guestlist/wrangler.jsonc",
    "typecheck": "tsgo --noEmit",
    "test": "vp test run"
  },
  "dependencies": {
    "@si/config": "workspace:*",
    "@somewhatintelligent/auth": "0.0.4-beta.1783733618.d38901c",
    "@somewhatintelligent/bouncer": "0.0.3-beta.1783733618.d38901c"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.6",
    "@si/typescript-config": "workspace:*",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "wrangler": "^4"
  },
  "portless": {
    "name": "somewhatintelligent",
    "script": "dev:bare"
  }
}
