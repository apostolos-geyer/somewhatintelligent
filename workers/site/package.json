{
  "name": "site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1 --port 4321",
    "build": "astro build",
    "preview": "astro preview --host 127.0.0.1 --port 4321",
    "env:init": "bun scripts/env-init.ts",
    "deploy:staging": "astro build && wrangler deploy",
    "deploy:production": "astro build && wrangler deploy --env production",
    "types": "wrangler types -c wrangler.jsonc",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^14.1.3",
    "@si/contracts": "workspace:*",
    "@si/design": "workspace:*",
    "astro": "7.0.9",
    "typescript": "5.9.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "wrangler": "^4"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
