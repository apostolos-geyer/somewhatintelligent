{
  "name": "site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless",
    "dev:bare": "astro dev --host 127.0.0.1 --port 4321",
    "build": "astro build",
    "preview": "astro preview --host 127.0.0.1 --port 4321",
    "env:init": "bun scripts/env-init.ts",
    "deploy:staging": "astro build && wrangler deploy",
    "deploy:production": "astro build && wrangler deploy --env production",
    "types": "wrangler types -c wrangler.jsonc",
    "typecheck": "astro check",
    "test": "vp test run"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^14.1.3",
    "@astrojs/react": "^6",
    "@si/contracts": "workspace:*",
    "@si/design": "workspace:*",
    "@stripe/react-stripe-js": "catalog:",
    "@stripe/stripe-js": "catalog:",
    "astro": "7.0.9",
    "hono": "^4.12.31",
    "markdown-it": "14.3.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "5.9.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "vite-plus": "catalog:",
    "wrangler": "^4"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "portless": {
    "name": "site.somewhatintelligent",
    "script": "dev:bare",
    "appPort": 4321
  }
}
