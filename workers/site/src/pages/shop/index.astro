---
import Base from "../../layouts/Base.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import friendImage from "../../../../../docs/design/somewhatintelligent-brand-study/reference-images/01-friend-elevator-incident.png";
---

<Base
  title="Objects — somewhatintelligent"
  description="Versioned clothing and physical goods published by somewhatintelligent."
>
  <div class="site-frame shop-frame">
    <SiteHeader active="shop" />

    <main class="shop-main">
      <section class="objects-intro" aria-labelledby="objects-title">
        <h1 id="objects-title">
          <span class="sr-only">Objects</span>
          <svg
            aria-hidden="true"
            class="objects-title-plane"
            preserveAspectRatio="none"
            viewBox="0 0 1000 1000"
          >
            <text x="20" y="912" font-size="1110" lengthAdjust="spacingAndGlyphs" textLength="930">
              OBJECTS
            </text>
          </svg>
        </h1>
        <p class="objects-deck">Artifacts for interface, code,<br />and the public we build.</p>
        <p class="objects-note">goods are<br />arguments<br />with sizing.</p>
      </section>

      <section class="object-ledger" aria-label="Object releases">
        <article class="object-entry object-entry-current" id="friend-001">
          <span class="object-number">01</span>
          <div class="object-meta">
            <h2>FRIEND-001</h2>
            <p>Release 1.0.0</p>
            <p>I think we should be friends*</p>
            <dl>
              <div><dt>Status</dt><dd>Available</dd></div>
              <div><dt>Price</dt><dd>$68 CAD</dd></div>
            </dl>
          </div>
          <figure class="object-image friend-front">
            <img src={friendImage.src} alt="Friend 001 front garment" />
          </figure>
          <figure class="object-image friend-back">
            <img src={friendImage.src} alt="Friend 001 back garment" />
          </figure>
          <div class="object-operational">
            <dl>
              <div><dt>Version</dt><dd>1.0.0</dd></div>
              <div><dt>Material</dt><dd>100% cotton</dd></div>
              <div><dt>Run</dt><dd>150 units</dd></div>
            </dl>
            <a href="/shop/friend-001/">View object <span aria-hidden="true">→</span></a>
          </div>
        </article>

        <article class="object-entry object-entry-compact object-entry-placeholder">
          <span class="object-number">02</span>
          <div class="object-meta">
            <h2>OBJECT FORTHCOMING</h2>
            <p>Release pending</p>
            <p>Placeholder record</p>
            <dl>
              <div><dt>Status</dt><dd>Unpublished</dd></div>
              <div><dt>Price</dt><dd>—</dd></div>
            </dl>
          </div>
          <div class="object-placeholder-field" aria-label="Object placeholder">
            <span>Object / unpublished</span>
            <strong>COMING SOON</strong>
          </div>
        </article>

        <article class="object-entry object-entry-compact object-entry-placeholder">
          <span class="object-number">03</span>
          <div class="object-meta">
            <h2>OBJECT FORTHCOMING</h2>
            <p>Release pending</p>
            <p>Placeholder record</p>
            <dl>
              <div><dt>Status</dt><dd>Unpublished</dd></div>
              <div><dt>Price</dt><dd>—</dd></div>
            </dl>
          </div>
          <div class="object-placeholder-field" aria-label="Object placeholder">
            <span>Object / unpublished</span>
            <strong>COMING SOON</strong>
          </div>
        </article>
      </section>
    </main>

    <SiteFooter />
  </div>
</Base>
