---
import Base from "../../layouts/Base.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import officeContactImage from "../../../../../docs/design/somewhatintelligent-brand-study/reference-images/04-intimate-office-contact.png";
---

<Base
  title="SYSTEM-001 — somewhatintelligent"
  description="A placeholder software record by somewhatintelligent."
>
  <div class="site-frame software-record-frame">
    <SiteHeader active="software" />

    <main class="software-record-main">
      <section class="software-record-sheet" aria-labelledby="software-record-title">
        <p class="software-record-kicker">System / SYSTEM-001</p>
        <h1 id="software-record-title">
          <span class="sr-only">Untitled system</span>
          <svg
            class="software-record-title-plane"
            viewBox="0 0 100 100"
            preserveAspectRatio="none"
            aria-hidden="true"
          >
            <text x="0" y="45" textLength="100" lengthAdjust="spacingAndGlyphs">UNTITLED</text>
            <text x="0" y="93" textLength="100" lengthAdjust="spacingAndGlyphs">SYSTEM</text>
          </svg>
        </h1>
        <p class="software-record-deck">
          A small piece of software.<br />Description forthcoming.
        </p>
        <a class="software-record-action" href="/software/">Open system <span>↗</span></a>
      </section>

      <figure class="software-record-primary software-record-placeholder">
        <span>Image / primary</span>
        <strong>System image</strong>
      </figure>

      <section class="software-record-details" aria-label="System details">
        <article>
          <h2>What it is</h2>
          <p>
            Placeholder copy for a concise description of the system, what it does, and why it
            exists.
          </p>
        </article>
        <article>
          <h2>Last updated</h2>
          <p>18 Jul 2026</p>
        </article>
      </section>

      <figure class="software-record-editorial">
        <img
          src={officeContactImage.src}
          alt="Two people in close contact over a desk covered with working papers"
        />
      </figure>
    </main>

    <SiteFooter />
  </div>
</Base>
