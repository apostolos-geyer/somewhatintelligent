---
import Base from "../../layouts/Base.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import SiteHeader from "../../components/SiteHeader.astro";

// Stripe's embedded confirm redirects here with ?session_id=…; the island polls
// the checkout-session status and clears the local cart on success.
// Transactional page: noindex.
---

<Base title="Order confirmation — somewhatintelligent" description="Order confirmation." noindex>
  <div class="site-frame">
    <SiteHeader active="shop" />

    <main class="tx-main">
      <section class="tx-panel" aria-labelledby="return-title">
        <h1 id="return-title">Order status</h1>

        <p id="return-loading" class="tx-status" aria-live="polite">Confirming your payment…</p>

        <div id="return-success" hidden>
          <p>Payment received. Thank you.</p>
          <p class="tx-order-number">Order <strong id="return-order-number"></strong></p>
          <a id="return-order-link" class="tx-button" href="#">
            View order <span aria-hidden="true">→</span>
          </a>
        </div>

        <div id="return-pending" hidden>
          <p>Your payment is still processing. This can take a moment — you can safely leave this
            page and check your order later.</p>
          <p id="return-pending-order" class="tx-order-number" hidden>
            Order <strong id="return-pending-number"></strong></p>
        </div>

        <div id="return-failed" hidden>
          <p>We could not confirm your payment.</p>
          <p><a href="/cart/">Return to cart <span aria-hidden="true">→</span></a></p>
        </div>

        <p id="return-error" class="tx-error" role="alert" hidden></p>
      </section>
    </main>

    <SiteFooter />
  </div>
</Base>

<script>
  import { fetchCheckoutStatus } from "../../lib/store-api-client";
  import { clearCart } from "../../lib/cart-client";

  const loadingEl = document.getElementById("return-loading");
  const successEl = document.getElementById("return-success");
  const pendingEl = document.getElementById("return-pending");
  const failedEl = document.getElementById("return-failed");
  const errorEl = document.getElementById("return-error");

  const MAX_ATTEMPTS = 8;
  const POLL_MS = 2000;

  function hideAll(): void {
    if (loadingEl) loadingEl.hidden = true;
    if (successEl) successEl.hidden = true;
    if (pendingEl) pendingEl.hidden = true;
    if (failedEl) failedEl.hidden = true;
    if (errorEl) errorEl.hidden = true;
  }

  function showError(message: string): void {
    hideAll();
    if (errorEl) {
      errorEl.textContent = message;
      errorEl.hidden = false;
    }
  }

  function showSuccess(orderNumber: string): void {
    clearCart();
    hideAll();
    const numEl = document.getElementById("return-order-number");
    const linkEl = document.getElementById("return-order-link");
    if (numEl) numEl.textContent = orderNumber;
    if (linkEl) linkEl.setAttribute("href", `/orders/${encodeURIComponent(orderNumber)}`);
    if (successEl) successEl.hidden = false;
  }

  function showPending(orderNumber: string | null): void {
    hideAll();
    if (orderNumber) {
      const wrap = document.getElementById("return-pending-order");
      const numEl = document.getElementById("return-pending-number");
      if (numEl) numEl.textContent = orderNumber;
      if (wrap) wrap.hidden = false;
    }
    if (pendingEl) pendingEl.hidden = false;
  }

  function showFailed(): void {
    hideAll();
    if (failedEl) failedEl.hidden = false;
  }

  async function poll(sessionId: string, attempt: number): Promise<void> {
    const res = await fetchCheckoutStatus(sessionId);

    if (!res.ok) {
      if (res.error === "unauthorized") {
        showError("Please sign in to view this order.");
        return;
      }
      // A freshly-created session may not be linked yet; retry a few times.
      if (attempt < MAX_ATTEMPTS) {
        window.setTimeout(() => void poll(sessionId, attempt + 1), POLL_MS);
        return;
      }
      showError(res.error === "not_found" ? "Order not found." : "Could not confirm your order.");
      return;
    }

    if (res.state === "paid") {
      showSuccess(res.orderNumber);
      return;
    }
    if (res.state === "failed") {
      showFailed();
      return;
    }
    // pending
    if (attempt < MAX_ATTEMPTS) {
      window.setTimeout(() => void poll(sessionId, attempt + 1), POLL_MS);
      return;
    }
    showPending(res.orderNumber);
  }

  const sessionId = new URLSearchParams(window.location.search).get("session_id");
  if (!sessionId) {
    showError("Missing checkout session.");
  } else {
    void poll(sessionId, 0);
  }
</script>

<style>
  .tx-main {
    min-height: 0;
    overflow-y: auto;
    padding: 40px 24px 80px;
  }

  .tx-panel {
    width: 100%;
    max-width: 560px;
    margin: 0 auto;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.5;
  }

  .tx-panel h1 {
    font-family: var(--font-display);
    font-size: 44px;
    letter-spacing: -0.02em;
  }

  .tx-status {
    margin-top: 24px;
  }

  .tx-panel a {
    text-decoration: underline;
  }

  .tx-order-number {
    margin-top: 16px;
    font-size: 14px;
  }

  .tx-error {
    margin-top: 24px;
    padding: 12px 14px;
    border: 1px solid var(--color-destructive);
    color: var(--color-destructive);
  }

  .tx-button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 48px;
    margin-top: 20px;
    padding: 0 28px;
    background: var(--color-inverse-foreground);
    color: var(--color-inverse);
    text-decoration: none !important;
    text-transform: uppercase;
    font-size: 14px;
  }
</style>
