---
import Base from "../layouts/Base.astro";
import HomeView from "../components/views/HomeView.astro";
import { getPage, publisherMediaHref } from "../lib/publisher-public";
import { DEFAULT_PAGE_DOCUMENTS } from "../lib/page-defaults";

// Copy/SEO come from the Publisher `home` page document (RFC-0001 D9). When the
// page has never been published the read returns `not_found`; the site-local
// default renders the committed copy so `/` is never blank.
const result = await getPage("home");
const doc = result.ok ? result.value.document : DEFAULT_PAGE_DOCUMENTS.home;
const ogImage = doc.seo.imageMediaId ? publisherMediaHref(doc.seo.imageMediaId) : null;
---

<Base title={doc.seo.title} description={doc.seo.description} ogImage={ogImage}>
  <HomeView document={doc} />
</Base>
