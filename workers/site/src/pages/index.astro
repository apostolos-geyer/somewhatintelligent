---
import Base from "../layouts/Base.astro";
import heroImage from "../../../../docs/design/somewhatintelligent-brand-study/reference-images/01-friend-elevator-incident.png";
import apparatusImage from "../../../../docs/design/somewhatintelligent-brand-study/reference-images/03-after-hours-apparatus.png";
---

<Base>
  <div class="site-frame">
    <header class="site-header">
      <a class="wordmark" href="/" aria-label="somewhatintelligent home">somewhatintelligent</a>
      <nav class="desktop-nav" aria-label="Primary">
        <a href="#objects">Shop</a>
        <a href="#systems">Software</a>
        <a href="#texts">Writing</a>
        <a href="#apostoli">About</a>
      </nav>
      <a class="cart-link" href="#objects" aria-label="Cart, zero items">
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M3 4h2l2.2 10.1a2 2 0 0 0 2 1.6h7.9a2 2 0 0 0 1.9-1.4L21 7H6" />
          <circle cx="10" cy="20" r="1" />
          <circle cx="18" cy="20" r="1" />
        </svg>
        <span>Cart</span>
        <span>0</span>
      </a>
    </header>

    <main class="home-main">
      <section class="hero" aria-labelledby="home-title">
        <div class="hero-claim">
          <h1 id="home-title">
            <span class="sr-only">Somewhat Intelligent</span>
            <svg
              aria-hidden="true"
              class="claim-plane"
              preserveAspectRatio="none"
              viewBox="0 0 1000 1000"
            >
              <text x="30" y="500" font-size="650" lengthAdjust="spacingAndGlyphs" textLength="870">
                SOMEWHAT
              </text>
              <text x="30" y="960" font-size="650" lengthAdjust="spacingAndGlyphs" textLength="935">
                INTELLIGENT
              </text>
            </svg>
          </h1>
          <p class="private-note">
            public interface.<br />
            private motive.
          </p>
          <p class="publishing-scope">objects, systems, texts, and other side effects</p>
        </div>
        <figure class="hero-image">
          <img src={heroImage.src} alt="Friend 001 garment photographed in an elevator" />
        </figure>
      </section>

      <section class="record-grid" aria-label="Current records">
        <article class="record" id="objects">
          <p class="record-label">Object / friend-001</p>
          <div class="record-visual object-visual">
            <img src={heroImage.src} alt="Friend 001 garment" />
          </div>
          <div class="record-copy">
            <p>Wearable field notes.<br />Printed in small runs.<br />100% cotton.</p>
            <p class="record-state">Release 1.0.0<br />Available</p>
            <a href="#objects">Shop now <span aria-hidden="true">→</span></a>
          </div>
        </article>

        <article class="record" id="systems">
          <p class="record-label">System / current</p>
          <div class="record-visual system-visual" aria-hidden="true">
            <span>+</span>
            <strong>AGENTIC<br />INBOX</strong>
          </div>
          <div class="record-copy">
            <p>A focused inbox operated by agents.<br />Triage. Draft. Ship.</p>
            <a href="#systems">Explore system <span aria-hidden="true">→</span></a>
          </div>
        </article>

        <article class="record" id="texts">
          <p class="record-label">Text / the cyber other</p>
          <div class="record-visual text-visual" aria-hidden="true">
            <strong>THE<br />CYBER<br />OTHER</strong>
            <small>notes on relation<br />beyond interface</small>
          </div>
          <div class="record-copy">
            <p>Critical writing on technology, intimacy, and power.<br />Printed and digital.</p>
            <a href="#texts">Read excerpt <span aria-hidden="true">→</span></a>
          </div>
        </article>

        <article class="record" id="apostoli">
          <p class="record-label">Apostoli / not for hire</p>
          <div class="record-visual apostoli-visual">
            <img src={apparatusImage.src} alt="After-hours publishing apparatus" />
          </div>
          <div class="record-copy">
            <p>Publisher, writer, operator.<br />The work is available. I am not.</p>
            <a href="#apostoli">Read the work <span aria-hidden="true">→</span></a>
          </div>
        </article>
      </section>
    </main>

    <footer class="site-footer">
      <span>somewhatintelligent</span>
      <span>© 2026 somewhatintelligent</span>
      <nav aria-label="Legal">
        <a href="#objects">Shipping</a>
        <a href="#objects">Refunds</a>
        <a href="#apostoli">Terms</a>
        <a href="#apostoli">Privacy</a>
      </nav>
    </footer>
  </div>
</Base>
