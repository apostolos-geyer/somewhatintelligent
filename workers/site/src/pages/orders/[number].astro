---
import Base from "../../layouts/Base.astro";
import TxShell from "../../components/TxShell.astro";

// Order detail for the owning customer. The STORE binding is the read-only
// catalog (no order methods), so the order is fetched client-side from
// /api/store/orders/:orderNumber, which the session cookie authenticates.
// Transactional page: noindex.
const { number } = Astro.params;
if (!number) {
  return new Response(null, { status: 404 });
}
---

<Base title={`Order ${number} — somewhatintelligent`} description="Order detail." noindex>
  <TxShell title="Order" maxWidth={640}>
    <p class="order-number-line" data-order-number={number}>Order <strong>{number}</strong></p>

    <p id="order-loading" class="tx-status" aria-live="polite">Loading order…</p>
    <p id="order-error" class="tx-error" role="alert" hidden></p>

    <div id="order-detail" hidden>
      <div class="order-status-row">
        <div>
          <span class="order-label">Status</span>
          <span id="order-status"></span>
        </div>
        <div>
          <span class="order-label">Payment</span>
          <span id="order-payment"></span>
        </div>
      </div>

      <ul id="order-items" class="order-items"></ul>
      <template id="order-item-tmpl">
        <li class="order-item">
          <span class="order-item-title"></span>
          <span class="order-item-qty"></span>
          <span class="order-item-price"></span>
        </li>
      </template>

      <dl class="order-totals">
        <div>
          <dt>Subtotal</dt>
          <dd id="order-subtotal"></dd>
        </div>
        <div>
          <dt>Shipping</dt>
          <dd id="order-shipping-cost"></dd>
        </div>
        <div class="order-total-row">
          <dt>Total</dt>
          <dd id="order-total"></dd>
        </div>
      </dl>

      <div id="order-ship" class="order-block" hidden>
        <h2>Shipping to</h2>
        <address id="order-ship-address"></address>
      </div>

      <div id="order-fulfillment" class="order-block" hidden>
        <h2>Fulfillment</h2>
        <p id="order-carrier" hidden></p>
        <p id="order-tracking" hidden></p>
      </div>
    </div>
  </TxShell>
</Base>

<script>
  import { fetchOrder } from "../../lib/store-api-client";
  import { formatPrice } from "../../lib/format";
  import type { OrderDetailDTO } from "@si/contracts";

  const STATUS_LABEL: Record<OrderDetailDTO["status"], string> = {
    pending: "Pending",
    paid: "Paid",
    shipped: "Shipped",
    delivered: "Delivered",
    cancelled: "Cancelled",
  };

  function setText(id: string, text: string): void {
    const el = document.getElementById(id);
    if (el) el.textContent = text;
  }

  function showError(message: string): void {
    const loadingEl = document.getElementById("order-loading");
    const errorEl = document.getElementById("order-error");
    if (loadingEl) loadingEl.hidden = true;
    if (errorEl) {
      errorEl.textContent = message;
      errorEl.hidden = false;
    }
  }

  function render(order: OrderDetailDTO): void {
    const loadingEl = document.getElementById("order-loading");
    const detailEl = document.getElementById("order-detail");
    if (loadingEl) loadingEl.hidden = true;

    setText("order-status", STATUS_LABEL[order.status] ?? order.status);
    setText("order-payment", order.paymentStatus);

    const itemsEl = document.getElementById("order-items");
    const tmpl = document.getElementById("order-item-tmpl") as HTMLTemplateElement | null;
    const itemRoot = tmpl?.content.firstElementChild ?? null;
    if (itemsEl && itemRoot) {
      itemsEl.replaceChildren();
      for (const it of order.items) {
        const node = itemRoot.cloneNode(true) as HTMLElement;
        const title = node.querySelector<HTMLElement>(".order-item-title");
        const qty = node.querySelector<HTMLElement>(".order-item-qty");
        const price = node.querySelector<HTMLElement>(".order-item-price");
        if (title) title.textContent = it.size ? `${it.title} — ${it.size}` : it.title;
        if (qty) qty.textContent = `×${it.quantity}`;
        if (price) price.textContent = formatPrice(it.unitPriceCents * it.quantity, "CAD");
        itemsEl.appendChild(node);
      }
    }

    setText("order-subtotal", formatPrice(order.subtotalCents, "CAD"));
    setText("order-shipping-cost", formatPrice(order.shippingCents, "CAD"));
    setText("order-total", formatPrice(order.totalCents, "CAD"));

    if (order.shipping) {
      const s = order.shipping;
      const parts = [
        s.name,
        s.line1,
        s.line2 ?? "",
        `${s.city}, ${s.region} ${s.postal}`,
        s.country,
      ].filter((line) => line.length > 0);
      const addr = document.getElementById("order-ship-address");
      if (addr) {
        addr.replaceChildren();
        for (const line of parts) {
          const div = document.createElement("div");
          div.textContent = line;
          addr.appendChild(div);
        }
      }
      document.getElementById("order-ship")?.removeAttribute("hidden");
    }

    if (order.carrier || order.trackingNumber) {
      const carrierEl = document.getElementById("order-carrier");
      const trackingEl = document.getElementById("order-tracking");
      if (order.carrier && carrierEl) {
        carrierEl.textContent = `Carrier: ${order.carrier}`;
        carrierEl.hidden = false;
      }
      if (order.trackingNumber && trackingEl) {
        trackingEl.textContent = `Tracking: ${order.trackingNumber}`;
        trackingEl.hidden = false;
      }
      document.getElementById("order-fulfillment")?.removeAttribute("hidden");
    }

    if (detailEl) detailEl.hidden = false;
  }

  // Runs on every soft navigation (astro:page-load fires on first load too).
  // Reads the order number from the freshly-swapped markup and bails when this
  // page is absent, so the handler no-ops on other routes.
  async function load(): Promise<void> {
    const root = document.querySelector<HTMLElement>("[data-order-number]");
    if (!root) return;
    const orderNumber = root.dataset.orderNumber ?? "";
    if (!orderNumber) {
      showError("Missing order number.");
      return;
    }
    const res = await fetchOrder(orderNumber);
    if (!res.ok) {
      if (res.error === "unauthorized") showError("Please sign in to view this order.");
      else if (res.error === "not_found") showError("Order not found.");
      else showError("Could not load this order.");
      return;
    }
    render(res.order);
  }

  document.addEventListener("astro:page-load", () => void load());
</script>

<style>
  .order-number-line {
    margin-top: 4px;
    color: var(--color-muted-foreground);
  }

  .order-status-row {
    display: flex;
    gap: 40px;
    margin-top: 28px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--color-border);
  }

  .order-label {
    display: block;
    font-size: 9px;
    text-transform: uppercase;
    color: var(--color-muted-foreground);
  }

  .order-items {
    margin-top: 20px;
    list-style: none;
  }

  .order-item {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto auto;
    gap: 16px;
    padding: 10px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .order-item-qty,
  .order-item-price {
    color: var(--color-muted-foreground);
  }

  .order-totals {
    margin-top: 20px;
  }

  .order-totals > div {
    display: flex;
    justify-content: space-between;
    padding: 4px 0;
  }

  .order-total-row {
    margin-top: 8px;
    padding-top: 12px;
    border-top: 1px solid var(--color-foreground);
    font-size: 16px;
  }

  .order-block {
    margin-top: 28px;
  }

  .order-block h2 {
    font-size: 9px;
    text-transform: uppercase;
    color: var(--color-muted-foreground);
  }

  .order-block address {
    margin-top: 8px;
    font-style: normal;
  }

  .order-block p {
    margin-top: 6px;
  }
</style>
