---
// Featured-latest ledger entry (RFC-0001 D9.1). Renders in-flow as the first
// child of the scrolling `.ledger-rows` container: a sticky headline `bar`
// (number / title / date / arrow) over an expandable `panel` (deck, excerpt,
// tags, CTA, image). As the container scrolls, a progressive-enhancement script
// sets `--ledger-collapse` (0→1) on the container; styles.css interpolates the
// title down to compact-row scale and collapses the panel away, leaving a
// pinned slim row. Base styles render the full entry statically, so a browser
// without the script (or with reduced motion) simply scrolls it away.
import type { PublicMediaRef } from "../../lib/publisher-public";

interface Props {
  kicker?: string;
  title: string;
  dateLabel: string;
  deck?: string | null;
  excerpt?: string | null;
  image: PublicMediaRef | null;
  imageLabel: string;
  tags?: string[];
  href: string;
  ctaLabel: string;
}

const { kicker, title, dateLabel, deck, excerpt, image, imageLabel, tags = [], href, ctaLabel } =
  Astro.props;
---

<article class="ledger-featured" id={href.split("/").pop()}>
  <a class="ledger-featured-bar" href={href}>
    <span class="ledger-featured-num">01</span>
    <span class="ledger-featured-headline">
      {kicker && <span class="ledger-featured-kicker">{kicker}</span>}
      <span class="ledger-featured-title">{title}</span>
    </span>
    <span class="ledger-featured-date">{dateLabel}</span>
    <span class="ledger-featured-arrow" aria-hidden="true">→</span>
  </a>
  <div class="ledger-featured-panel">
    <div class="ledger-featured-copy">
      {deck && <p class="ledger-featured-deck">{deck}</p>}
      {excerpt && <p class="ledger-featured-excerpt">{excerpt}</p>}
      {tags.length > 0 && <p class="ledger-featured-tags">{tags.join(" · ")}</p>}
      <a class="ledger-featured-cta" href={href}>
        {ctaLabel} <span aria-hidden="true">→</span>
      </a>
    </div>
    {
      image ? (
        <figure class="ledger-featured-image">
          <img src={image.href} alt={image.alt || title} />
        </figure>
      ) : (
        <div class="object-placeholder-field ledger-featured-placeholder" aria-label="No image">
          <span>{imageLabel}</span>
          <strong>NO IMAGE</strong>
        </div>
      )
    }
  </div>
  <script is:inline>
    (function () {
      var script = document.currentScript;
      if (!script) return;
      var featured = script.closest(".ledger-featured");
      var container = featured && featured.closest(".ledger-rows");
      if (!container) return;
      if (window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches)
        return;
      container.classList.add("is-collapsible");

      // Calibrate the collapse range to the actual featured-height delta so a
      // pixel of scroll maps ~1:1 to a pixel of shrink (no dead zone or jump).
      // Measured by forcing each end and reading the laid-out height.
      var RANGE = 320;
      function set(p) {
        container.style.setProperty("--ledger-collapse", p);
      }
      function measure() {
        set("0");
        var fullH = featured.getBoundingClientRect().height;
        set("1");
        var collapsedH = featured.getBoundingClientRect().height;
        RANGE = Math.max(1, fullH - collapsedH);
        apply();
      }
      var ticking = false;
      function apply() {
        ticking = false;
        var p = container.scrollTop / RANGE;
        p = p < 0 ? 0 : p > 1 ? 1 : p;
        set(p.toFixed(4));
      }
      function onScroll() {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(apply);
        }
      }
      container.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", measure, { passive: true });
      measure();
    })();
  </script>
</article>
