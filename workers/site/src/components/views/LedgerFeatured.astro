---
// Thin wrapper preserving the old featured-entry prop contract (consumed by
// /writing and its PagePreview branch, unowned by the /software rework) over
// the unified LedgerEntry — always entry 01, always starting expanded.
import LedgerEntry from "./LedgerEntry.astro";
import type { PublicMediaRef } from "../../lib/publisher-public";

interface Props {
  kicker?: string;
  title: string;
  dateLabel: string;
  deck?: string | null;
  excerpt?: string | null;
  image: PublicMediaRef | null;
  imageLabel: string;
  tags?: string[];
  href: string;
  ctaLabel: string;
}

const { kicker, title, dateLabel, deck, excerpt, image, imageLabel, tags, href, ctaLabel } =
  Astro.props;
---

<LedgerEntry
  index={1}
  kicker={kicker}
  title={title}
  dateLabel={dateLabel}
  deck={deck}
  excerpt={excerpt}
  image={image}
  imageLabel={imageLabel}
  tags={tags}
  href={href}
  ctaLabel={ctaLabel}
  startExpanded
/>
