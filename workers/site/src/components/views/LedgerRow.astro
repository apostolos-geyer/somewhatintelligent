---
// Thin wrapper preserving the old compact-row prop contract (consumed by
// /writing and its PagePreview branch, unowned by the /software rework) over
// the unified LedgerEntry — collapsed by default, no image/deck data.
import LedgerEntry from "./LedgerEntry.astro";

interface Props {
  index: number;
  title: string;
  dateLabel: string;
  tags?: string[];
  href: string;
}

const { index, title, dateLabel, tags, href } = Astro.props;
---

<LedgerEntry index={index} title={title} dateLabel={dateLabel} tags={tags} href={href} />
