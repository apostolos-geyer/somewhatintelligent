---
import SiteFooter from "./SiteFooter.astro";
import SiteHeader from "./SiteHeader.astro";

// Shared chrome + shell styles for the transactional pages (cart, checkout,
// checkout return, order detail): site-frame + header/footer + a centered
// mono panel. The page body is the default slot. SiteHeader derives its active
// section from the URL, so no active prop is passed.
interface Props {
  title: string;
  maxWidth?: number;
}

const { title, maxWidth } = Astro.props;
---

<div class="site-frame">
  <SiteHeader />

  <main class="tx-main">
    <section
      class="tx-panel"
      aria-labelledby="tx-title"
      style={`--tx-panel-max-width:${maxWidth ?? 560}px`}
    >
      <h1 id="tx-title">{title}</h1>
      <slot />
    </section>
  </main>

  <SiteFooter />
</div>

<style>
  .tx-main {
    min-height: 0;
    overflow-y: auto;
    padding: 40px 24px 80px;
  }

  .tx-panel {
    width: 100%;
    max-width: var(--tx-panel-max-width, 560px);
    margin: 0 auto;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.5;
  }

  .tx-panel h1 {
    font-family: var(--font-display);
    font-size: 44px;
    letter-spacing: -0.02em;
  }

  /* Slotted content is not reached by scoped selectors, so the shared shell
     classes the page bodies use are matched globally but narrowed under the
     shell-owned, scoped .tx-panel. */
  .tx-panel :global(.tx-status) {
    margin-top: 24px;
  }

  .tx-panel :global(.tx-status a) {
    text-decoration: underline;
  }

  .tx-panel :global(.tx-error) {
    margin-top: 24px;
    padding: 12px 14px;
    border: 1px solid var(--color-destructive);
    color: var(--color-destructive);
  }

  .tx-panel :global(.tx-order-number) {
    margin-top: 16px;
    font-size: 14px;
  }

  .tx-panel :global(.tx-button) {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 48px;
    margin-top: 20px;
    padding: 0 28px;
    background: var(--color-inverse-foreground);
    color: var(--color-inverse);
    font-size: 14px;
    text-transform: uppercase;
    text-decoration: none;
  }

  .tx-panel :global(.tx-button--block) {
    justify-content: center;
    width: 100%;
    margin-top: 24px;
  }

  .tx-panel :global(.tx-button[aria-disabled="true"]),
  .tx-panel :global(.tx-button:disabled) {
    opacity: 0.4;
    cursor: not-allowed;
  }
</style>
