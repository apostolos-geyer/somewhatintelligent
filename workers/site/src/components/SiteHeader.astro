---
interface Props {
  active: "about" | "home" | "shop" | "software" | "writing";
}

const { active } = Astro.props;
---

<header class="site-header">
  <a
    class:list={["wordmark", { "is-active": active === "home" }]}
    href="/"
    aria-label="somewhatintelligent home"
  >
    somewhatintelligent
  </a>
  <nav class="desktop-nav" aria-label="Primary">
    <a class:list={{ "is-active": active === "shop" }} href="/shop/">Shop</a>
    <a class:list={{ "is-active": active === "software" }} href="/software/">Software</a>
    <a class:list={{ "is-active": active === "writing" }} href="/writing/">Writing</a>
    <a class:list={{ "is-active": active === "about" }} href="/about/">About</a>
  </nav>
  <div class="header-end">
    <a class="account-link" href="#account">Account</a>
    <a class="cart-link" href="#cart" aria-label="Cart, zero items">
      <svg aria-hidden="true" viewBox="0 0 24 24">
        <path d="M3 4h2l2.2 10.1a2 2 0 0 0 2 1.6h7.9a2 2 0 0 0 1.9-1.4L21 7H6" />
        <circle cx="10" cy="20" r="1" />
        <circle cx="18" cy="20" r="1" />
      </svg>
      <span>Cart</span>
      <span>(0)</span>
    </a>
  </div>
</header>
