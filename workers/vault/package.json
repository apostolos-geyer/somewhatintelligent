{
  "name": "@si/vault-service",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client/index.ts"
  },
  "scripts": {
    "dev": "WRANGLER_REGISTRY_PATH=${WRANGLER_REGISTRY_PATH:-$PWD/../../.wrangler/dev-registry} wrangler dev --port ${VAULT_PORT:-8791} --inspector-port ${VAULT_INSPECTOR_PORT:-0}",
    "env:init": "bun scripts/env-init.ts",
    "dev:solo": "bun ../../scripts/dev-solo.ts",
    "deploy:staging": "wrangler deploy",
    "deploy:production": "wrangler deploy --env production",
    "build": "wrangler deploy --dry-run",
    "db:generate": "drizzle-kit generate",
    "types": "wrangler types -c wrangler.jsonc",
    "typecheck": "tsgo --noEmit",
    "test": "vp test run"
  },
  "dependencies": {
    "@somewhatintelligent/kit": "0.0.3",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@cloudflare/vitest-pool-workers": "^0.14.6",
    "@cloudflare/workers-types": "^4",
    "@rolldown/plugin-babel": "^0.2.3",
    "@si/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "drizzle-kit": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "wrangler": "^4"
  }
}
